{
  "train_batch_size": 256,
  "gradient_accumulation_steps": 1,
  "optimizer": {
    "type": "Adam",
    "params": {
      "lr": 0.001,
      "betas": [
        0.9,
        0.999
      ],
      "eps": 1e-7,
      "weight_decay": 1e-3
    }
  },
  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "warmup_min_lr": 1e-5,
      "warmup_max_lr": 0.001,
      "warmup_num_steps": 100,
      "total_num_steps": 20000
    }
  },
  "fp16": {
    "enabled": false
  },
  "zero_optimization": {
    "stage": 0
  },
  "steps_per_print": 100,
  "wall_clock_breakdown": false
}